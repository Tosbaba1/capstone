<% participant_status = @participant.completed? ? "Completed" : "Abandoned" %>
<% credited_minutes = @participant.credited_minutes %>
<% host_name = @session.host_user.name.presence || @session.host_user.username.presence || "A reader" %>
<% current_book = @current_reading&.book %>
<% current_author = current_book&.author&.name %>
<% mode_name = @session.mode == "structured" ? "Structured Mode" : "Silent Mode" %>
<% mode_prompt = @session.mode == "structured" ? "Suggested structure: read 10 pages or one short chapter." : "Settle into the quiet. Presence stays in the background while everyone reads." %>
<% initial_countdown = format("%02d:%02d", @presence_snapshot[:remaining_seconds] / 60, @presence_snapshot[:remaining_seconds] % 60) %>
<% other_reader_count = @session.other_reader_count_for(current_user) %>
<% current_streak = current_user.current_reading_streak %>
<% show_presence_avatars = @presence_snapshot[:presence_visibility] == "avatars" %>

<section class="session-room <%= "session-room--immersive" if @immersive_session_room %>">
  <article class="session-room__panel <%= "session-room__panel--immersive" if @immersive_session_room %>">
    <% if @participant.leave_time.present? %>
      <% if @participant.completed? %>
        <div class="session-room__summary-shell session-room__summary-shell--completion">
          <p class="session-room__summary-label mb-1"><%= participant_status %></p>
          <h1 class="session-room__summary-title mb-2"><%= "You read for #{credited_minutes} minutes" %></h1>
          <p class="session-room__summary-copy mb-0">
            <% if other_reader_count.positive? %>
              <%= "#{pluralize(other_reader_count, "other person")} read with you." %>
            <% else %>
              You read solo — great work.
            <% end %>
          </p>
          <p class="session-room__summary-encouragement mb-0">Come back tomorrow.</p>

          <div class="session-room__summary-metrics">
            <div class="session-room__summary-metric">
              <span>This week</span>
              <strong><%= reading_time_label(current_user.reading_time_this_week) %></strong>
            </div>
            <div class="session-room__summary-metric">
              <span>Sessions completed</span>
              <strong><%= pluralize(current_user.completed_session_count, "session") %></strong>
            </div>
            <div class="session-room__summary-metric">
              <span>Current streak</span>
              <strong><%= streak_label(current_streak) %></strong>
            </div>
          </div>

          <div class="session-room__actions">
            <%= link_to "Done", home_path, class: "sessions-home__primary-action sessions-home__primary-action--inline" %>
          </div>
        </div>
      <% else %>
        <div class="session-room__summary-shell">
          <p class="session-room__summary-label mb-1"><%= participant_status %></p>
          <h1 class="session-room__summary-title mb-2"><%= "You read for #{credited_minutes} minutes" %></h1>
          <p class="session-room__summary-copy mb-0">
            This session did not count because you left before the halfway point. Stay for more than half the timer next time and we will save it to your progress.
          </p>

          <div class="session-room__summary-metrics">
            <div class="session-room__summary-metric">
              <span>Mode</span>
              <strong><%= mode_name %></strong>
            </div>
            <div class="session-room__summary-metric">
              <span>Duration</span>
              <strong><%= "#{@session.duration} minutes" %></strong>
            </div>
            <div class="session-room__summary-metric">
              <span>Hosted by</span>
              <strong><%= host_name %></strong>
            </div>
          </div>

          <div class="session-room__actions">
            <%= link_to "Done", home_path, class: "sessions-home__primary-action sessions-home__primary-action--inline" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div
        class="session-room__active"
        data-controller="session-room"
        data-session-room-active-value="true"
        data-session-room-ends-at-value="<%= @presence_snapshot[:ends_at] %>"
        data-session-room-server-now-value="<%= @presence_snapshot[:server_now] %>"
        data-session-room-heartbeat-url-value="<%= heartbeat_session_path(@session) %>"
        data-session-room-presence-url-value="<%= presence_session_path(@session) %>"
        data-session-room-complete-url-value="<%= complete_session_path(@session) %>"
        data-session-room-default-avatar-url-value="<%= asset_path("default_avatar.png") %>"
        data-session-room-presence-visibility-value="<%= @presence_snapshot[:presence_visibility] %>"
      >
        <header class="session-room__topbar">
          <div class="session-room__topbar-copy">
            <p class="session-room__timer-label mb-0">Your session is waiting.</p>
          </div>
          <%= button_to "Leave session", leave_session_path(@session), method: :post, class: "session-room__exit-button" %>
        </header>

        <section class="session-room__timer-stage">
          <p class="session-room__timer-label mb-0">Reading Session</p>
          <strong class="session-room__timer-value" data-session-room-target="countdown"><%= initial_countdown %></strong>
          <p class="session-room__meta-line mb-0"><%= "#{@session.duration} min • #{mode_name} • Hosted by #{host_name}" %></p>
        </section>

        <section class="session-room__focus-stage">
          <div class="session-room__focus-copy">
            <% if current_book.present? %>
              <p class="session-room__focus-label mb-1">Currently reading</p>
              <h1 class="session-room__focus-title mb-2"><%= current_book.title %></h1>
              <p class="session-room__focus-author mb-0">
                <% if current_author.present? %>
                  by <%= current_author %>
                <% else %>
                  Stay with your current book for the rest of this session.
                <% end %>
              </p>
              <% if @current_reading.progress.present? %>
                <p class="session-room__focus-progress mb-0"><%= "#{@current_reading.progress}% through" %></p>
              <% end %>
            <% else %>
              <p class="session-room__focus-label mb-1">Settle in</p>
              <h1 class="session-room__focus-title mb-2">A calm room for uninterrupted reading.</h1>
              <p class="session-room__focus-author mb-0">Bring the book you want to spend time with. The room stays quiet while everyone reads.</p>
            <% end %>
          </div>

          <aside class="session-room__focus-note">
            <% if current_book&.image_url.present? %>
              <%= image_tag(current_book.image_url, alt: "#{current_book.title} cover", class: "session-room__book-cover") %>
            <% else %>
              <div class="session-room__book-placeholder" aria-hidden="true">
                <span><%= current_book&.title&.first&.upcase || "N" %></span>
              </div>
            <% end %>

            <div class="session-room__focus-note-copy">
              <p class="session-room__focus-note-label mb-1"><%= mode_name %></p>
              <p class="session-room__focus-note-text mb-2"><%= mode_prompt %></p>
              <p class="session-room__focus-note-text mb-0">Staying for more than half the timer counts as a completed session, even if you leave before the end.</p>
            </div>
          </aside>
        </section>

        <footer class="session-room__presence-shell">
          <div class="session-room__presence-copy">
            <p class="session-room__timer-label mb-1">Quiet company</p>
            <h2 class="session-room__presence-count mb-1" data-session-room-target="readerCount">
              <%= pluralize(@presence_snapshot[:active_reader_count], "reader") %>
            </h2>
            <p class="session-room__presence-caption mb-0">
              <% if show_presence_avatars %>
                Presence is intentionally light here. No chat, no comments, just other readers keeping time with you.
              <% else %>
                Presence stays intentionally abstract here. You can feel the room without exposing who is inside it.
              <% end %>
            </p>
          </div>

          <div class="session-room__presence-body">
            <% if show_presence_avatars %>
              <div class="session-room__presence-avatars" data-session-room-target="avatarStack">
                <% @presence_snapshot[:readers].each do |reader| %>
                  <%= image_tag(reader[:avatar].presence || "default_avatar.png", alt: reader[:name], class: "session-room__presence-avatar") %>
                <% end %>

                <% overflow_count = @presence_snapshot[:active_reader_count] - @presence_snapshot[:readers].size %>
                <% if overflow_count.positive? %>
                  <span class="session-room__presence-overflow"><%= "+#{overflow_count}" %></span>
                <% end %>
              </div>

              <div class="session-room__reader-list" data-session-room-target="readerList">
                <% @presence_snapshot[:readers].each do |reader| %>
                  <span class="session-room__reader-pill">
                    <strong><%= reader[:name] %></strong>
                    <small>
                      <% if reader[:host] && reader[:current_user] %>
                        You, hosting
                      <% elsif reader[:host] %>
                        Host
                      <% elsif reader[:current_user] %>
                        You
                      <% else %>
                        Reading now
                      <% end %>
                    </small>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
        </footer>
      </div>
    <% end %>
  </article>
</section>

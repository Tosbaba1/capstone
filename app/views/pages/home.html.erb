<% live_presence_label = "Reading now: #{pluralize(@live_presence_count, 'person')}" %>

<section class="sessions-home">
  <header class="sessions-home__hero mb-4">
    <div class="sessions-home__hero-copy">
      <p class="sessions-home__eyebrow mb-2">Live Presence</p>
      <h1 class="sessions-home__title mb-2"><%= live_presence_label %></h1>
      <p class="sessions-home__lede mb-0">
        A calm front door into reading. Step into an open session, or begin one and let the room fill around you.
      </p>
    </div>

    <div class="presence-rail">
      <div class="presence-rail__stat">
        <span class="presence-rail__label">Open sessions</span>
        <span class="presence-rail__value"><%= @active_sessions.count %></span>
      </div>
      <div class="presence-rail__stat">
        <span class="presence-rail__label">On your shelf</span>
        <span class="presence-rail__value"><%= @progress_snapshot[:reading] + @progress_snapshot[:queued] %></span>
      </div>

      <% if @presence_readers.any? %>
        <div class="presence-rail__readers">
          <div class="presence-avatars" aria-hidden="true">
            <% @presence_readers.first(4).each do |reader| %>
              <%= image_tag(reader.avatar.presence || "default_avatar.png", alt: "", class: "presence-avatars__image") %>
            <% end %>
          </div>
          <% reader_names = @presence_readers.first(3).map { |reader| reader.name.presence || reader.username.presence || "A reader" } %>
          <p class="presence-rail__caption mb-0">
            <%= reader_names.to_sentence %>
            <% if @live_presence_count > 3 %>
              and others are already reading.
            <% else %>
              are already reading.
            <% end %>
          </p>
        </div>
      <% else %>
        <p class="presence-rail__caption mb-0">The room is quiet right now, which makes it a good moment to begin.</p>
      <% end %>
    </div>
  </header>

  <div class="sessions-home__grid">
    <section class="sessions-home__panel">
      <div class="sessions-home__panel-head">
        <div>
          <p class="sessions-home__section-eyebrow mb-1">Active Sessions</p>
          <h2 class="sessions-home__section-title mb-1">Open tables you can join right now.</h2>
          <p class="sessions-home__section-copy mb-0">These rooms now run on real session records, presence polling, and completion tracking.</p>
        </div>
      </div>

      <% if @active_sessions.any? %>
        <div class="session-stack">
          <% @active_sessions.each do |session| %>
            <%= render "session_card", session: session, current_session_participant: @current_session_participant %>
          <% end %>
        </div>
      <% else %>
        <div class="sessions-home__empty-state">
          <p class="mb-1">Be the first to start a session.</p>
          <p class="mb-0">Once someone begins reading, the room will appear here with a join path for the next person.</p>
        </div>
      <% end %>
    </section>

    <section class="sessions-home__panel">
      <div class="sessions-home__panel-head">
        <div>
          <p class="sessions-home__section-eyebrow mb-1">Session Entry</p>
          <h2 class="sessions-home__section-title mb-1">Choose the easiest book to sit down with.</h2>
          <p class="sessions-home__section-copy mb-0">Home should shorten the distance between opening the app and actually reading.</p>
        </div>
      </div>

      <% if @session_entry_readings.any? %>
        <div class="entry-stack">
          <% @session_entry_readings.each do |reading| %>
            <% book = reading.book %>
            <% author_name = book.author&.name.presence || "Unknown author" %>
            <% action_label = reading.status == "reading" ? "Continue session" : "Start from this book" %>
            <% next_progress = reading.status == "finished" ? 0 : reading.progress.to_i %>

            <article class="entry-card">
              <div class="entry-card__top">
                <div>
                  <p class="entry-card__eyebrow mb-1"><%= reading.status == "reading" ? "Ready to continue" : "Ready to begin" %></p>
                  <h3 class="entry-card__title mb-1"><%= book.title %></h3>
                  <p class="entry-card__author mb-0">by <%= author_name %></p>
                </div>
                <span class="entry-card__metric">
                  <%= reading.status == "reading" ? "#{reading.progress.presence || 0}% in" : "Queued" %>
                </span>
              </div>

              <div class="entry-card__actions">
                <% if reading.status == "reading" %>
                  <%= link_to action_label, book_path(book), class: "sessions-home__secondary-action sessions-home__secondary-action--compact" %>
                <% else %>
                  <%= button_to action_label,
                    update_reading_path(reading),
                    method: :post,
                    params: { status: "reading", progress: next_progress, return_to: home_path },
                    class: "sessions-home__secondary-action sessions-home__secondary-action--button sessions-home__secondary-action--compact" %>
                <% end %>
                <%= link_to "Open book", book_path(book), class: "entry-card__link" %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="sessions-home__empty-state">
          <p class="mb-1">Your shelf is still empty.</p>
          <p class="mb-3">Add a book first, then Home can turn it into an immediate reading entry point.</p>
          <div class="sessions-home__inline-actions">
            <%= link_to "Find a book", search_path(tab: "books"), class: "sessions-home__secondary-action sessions-home__secondary-action--compact" %>
            <%= link_to "Open library", library_path, class: "entry-card__link" %>
          </div>
        </div>
      <% end %>

      <div class="progress-strip">
        <article class="progress-strip__card">
          <span class="progress-strip__value"><%= @progress_snapshot[:reading] %></span>
          <span class="progress-strip__label">Reading</span>
        </article>
        <article class="progress-strip__card">
          <span class="progress-strip__value"><%= @progress_snapshot[:queued] %></span>
          <span class="progress-strip__label">Queued</span>
        </article>
        <article class="progress-strip__card">
          <span class="progress-strip__value"><%= @progress_snapshot[:finished] %></span>
          <span class="progress-strip__label">Finished</span>
        </article>
      </div>
    </section>
  </div>

  <section class="sessions-home__panel sessions-home__panel--cta mt-4">
    <div>
      <p class="sessions-home__section-eyebrow mb-1">Primary Action</p>
      <h2 class="sessions-home__section-title mb-1">Start reading before anything else competes for attention.</h2>
      <p class="sessions-home__section-copy mb-0">Choose a duration, pick silent or structured mode, and step straight into the timer.</p>
    </div>

    <div class="sessions-home__cta-actions">
      <% if @current_session_participant.present? %>
        <%= link_to "Return to Active Session", session_path(@current_session_participant.session), class: "sessions-home__primary-action sessions-home__primary-action--hero" %>
        <%= link_to "Start New Session", new_session_path, class: "sessions-home__secondary-action" %>
      <% else %>
        <%= link_to "Start Reading Session", new_session_path, class: "sessions-home__primary-action sessions-home__primary-action--hero" %>
        <%= link_to "Open library", library_path, class: "sessions-home__secondary-action" %>
      <% end %>
    </div>
  </section>

  <section class="sessions-home__panel mt-4">
    <div class="sessions-home__panel-head">
      <div>
        <p class="sessions-home__section-eyebrow mb-1">Secondary Surfaces</p>
        <h2 class="sessions-home__section-title mb-1">Library, search, and feed remain available without taking over Home.</h2>
        <p class="sessions-home__section-copy mb-0">The social layer still exists, but it now sits behind the session loop instead of ahead of it.</p>
      </div>
    </div>

    <div class="secondary-surface-grid">
      <%= link_to library_path, class: "secondary-surface-card" do %>
        <span class="secondary-surface-card__eyebrow">Library</span>
        <strong class="secondary-surface-card__title">Manage your shelves</strong>
        <span class="secondary-surface-card__copy">Adjust status, privacy, and progress when you need to.</span>
      <% end %>

      <%= link_to search_path(tab: "books"), class: "secondary-surface-card" do %>
        <span class="secondary-surface-card__eyebrow">Search</span>
        <strong class="secondary-surface-card__title">Find your next book</strong>
        <span class="secondary-surface-card__copy">Browse titles without breaking the calm session-first structure.</span>
      <% end %>

      <%= link_to posts_path, class: "secondary-surface-card" do %>
        <span class="secondary-surface-card__eyebrow">Feed</span>
        <strong class="secondary-surface-card__title">Reading updates</strong>
        <span class="secondary-surface-card__copy">The feed is preserved as its own surface instead of driving the Home page.</span>
      <% end %>
    </div>

    <% if @recent_post.present? %>
      <% recent_author = @recent_post.creator.name.presence || @recent_post.creator.username.presence || "A reader" %>
      <% recent_book = @recent_post.book&.title.presence || "their current read" %>
      <article class="feed-teaser">
        <p class="feed-teaser__eyebrow mb-1">Latest from the feed</p>
        <p class="feed-teaser__copy mb-2">
          <strong><%= recent_author %></strong> shared an update about <strong><%= recent_book %></strong>.
        </p>
        <%= link_to "Open the feed", posts_path, class: "entry-card__link" %>
      </article>
    <% end %>
  </section>
</section>

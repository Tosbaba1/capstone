<% if @user == current_user %>
  <ul class="nav nav-tabs mb-4">
    <li class="nav-item">
      <%= link_to 'Public', library_path(tab: 'public'), class: "nav-link #{@active_tab == 'public' ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Private', library_path(tab: 'private'), class: "nav-link #{@active_tab == 'private' ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Ask Librarian', library_path(tab: 'ai'), class: "nav-link #{@active_tab == 'ai' ? 'active' : ''}" %>
    </li>
  </ul>
<% end %>

<% if @active_tab == 'ai' %>
  <%= render 'library_ai_chat' %>
<% else %>
  <% editable = @user == current_user %>
  <% library_title = editable ? 'Your Library' : "#{@user.name}'s Library" %>
  <% shelf_label = editable ? (@active_tab == 'private' ? 'Private shelf' : 'Public shelf') : 'Public shelf' %>

  <section class="library-shell">
    <header class="library-hero mb-4">
      <p class="library-hero__eyebrow mb-2">Reading Journal</p>
      <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end">
        <div>
          <h1 class="library-hero__title mb-2"><%= library_title %></h1>
          <p class="library-hero__copy mb-0">
            A calmer shelf view for the books you are keeping close right now.
          </p>
        </div>
        <div class="library-hero__pill">
          <span><%= shelf_label %></span>
        </div>
      </div>
    </header>

    <%= render 'library_shelf_section',
      title: 'Currently Reading',
      subtitle: 'Books with your bookmark still tucked inside.',
      readings: @reading_now,
      editable: editable %>

    <%= render 'library_shelf_section',
      title: 'Want to Read',
      subtitle: 'Books waiting patiently in your next-up stack.',
      readings: @want_to_read,
      editable: editable %>

    <%= render 'library_shelf_section',
      title: 'Finished',
      subtitle: 'Books you have already carried all the way to the last page.',
      readings: @finished,
      editable: editable %>
  </section>
<% end %>

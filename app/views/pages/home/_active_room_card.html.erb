<% host_name = session.host_user.name.presence || session.host_user.username.presence || "A reader" %>
<% current_session_id = current_session_participant&.session_id %>
<% started_at = session.created_at.in_time_zone %>

<article class="home-room-card">
  <div class="home-room-card__meta">
    <span class="home-room-card__badge"><%= pluralize(session.active_reader_count, "reader") %></span>
    <span class="home-room-card__time">Started <%= started_at.strftime("%-I:%M %p") %></span>
  </div>

  <div class="home-room-card__body">
    <h3 class="home-room-card__title mb-1"><%= "#{session.duration} min #{session.mode.titleize}" %></h3>
    <p class="home-room-card__copy mb-0">Hosted by <%= host_name %></p>
  </div>

  <div class="home-room-card__actions">
    <% if current_session_id == session.id %>
      <%= link_to "Return to room", session_path(session), class: "sessions-home__secondary-action sessions-home__secondary-action--compact" %>
    <% else %>
      <%= button_to "Join room",
        join_session_path(session),
        method: :post,
        class: "sessions-home__secondary-action sessions-home__secondary-action--button sessions-home__secondary-action--compact" %>
    <% end %>

    <%= link_to "View room", session_path(session), class: "entry-card__link home-room-card__link" %>
  </div>
</article>

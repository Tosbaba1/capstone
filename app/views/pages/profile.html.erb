<% profile_name = current_user.name.presence || current_user.username.presence || "Reader" %>
<% profile_handle = current_user.username.presence || current_user.email.to_s.split("@").first %>
<% profile_tab = params[:tab] == "sessions" ? "sessions" : "overview" %>
<% latest_session = @latest_completed_session %>
<% latest_companion_count = latest_session.present? ? latest_session.session.other_reader_count_for(current_user) : 0 %>

<section class="profile-progress app-page-stack">
  <article class="profile-progress__hero">
    <div class="profile-progress__identity-row">
      <%= image_tag(current_user.avatar.presence || "default_avatar.png", alt: profile_name, class: "profile-progress__avatar") %>

      <div class="profile-progress__identity-copy">
        <% if current_user.banner.present? %>
          <p class="profile-progress__banner mb-2"><%= current_user.banner %></p>
        <% end %>

        <div class="profile-progress__identity-heading">
          <div>
            <h1 class="profile-progress__title mb-1"><%= profile_name %></h1>
            <p class="profile-progress__handle mb-0"><%= "@#{profile_handle}" %></p>
          </div>

          <% if @current_streak.positive? %>
            <div class="profile-progress__streak">
              <span class="profile-progress__streak-marker" aria-hidden="true"></span>
              <span><%= streak_label(@current_streak) %></span>
            </div>
          <% end %>
        </div>

        <% if current_user.bio.present? %>
          <p class="profile-progress__bio mb-0"><%= current_user.bio %></p>
        <% end %>
      </div>
    </div>

    <div class="profile-progress__actions">
      <% if @current_session_participant.present? %>
        <%= link_to "Start reading", session_path(@current_session_participant.session), class: "sessions-home__primary-action sessions-home__primary-action--inline" %>
      <% else %>
        <%= link_to "Start reading", new_session_path, class: "sessions-home__primary-action sessions-home__primary-action--inline" %>
      <% end %>
      <%= link_to "Edit profile", edit_user_registration_path, class: "sessions-home__secondary-action" %>
    </div>
  </article>

  <ul class="nav nav-tabs app-tabs-row profile-progress__tabs">
    <li class="nav-item">
      <%= link_to "Overview", profile_path, class: "nav-link #{profile_tab == 'overview' ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to "Sessions", profile_path(tab: "sessions"), class: "nav-link #{profile_tab == 'sessions' ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to "Public profile", user_path(current_user), class: "nav-link" %>
    </li>
  </ul>

  <% if profile_tab == "overview" %>
    <section class="profile-progress__summary-grid">
      <div class="profile-progress__stats">
        <div class="profile-progress__stat">
          <span class="profile-progress__stat-label">This week</span>
          <strong class="profile-progress__stat-value"><%= reading_time_label(@weekly_reading_time) %></strong>
        </div>
        <div class="profile-progress__stat">
          <span class="profile-progress__stat-label">Sessions</span>
          <strong class="profile-progress__stat-value"><%= @sessions_completed %></strong>
        </div>
        <div class="profile-progress__stat">
          <span class="profile-progress__stat-label">Streak</span>
          <strong class="profile-progress__stat-value"><%= streak_label(@current_streak) %></strong>
        </div>
      </div>
    </section>

    <section class="profile-progress__panel profile-progress__panel--latest">
      <p class="profile-progress__eyebrow mb-1">Latest session</p>
      <% if latest_session.present? %>
        <h2 class="profile-progress__panel-title mb-2">
          <%= "#{latest_session.credited_minutes} minute #{latest_session.session.mode == "structured" ? "Structured" : "Silent"} session" %>
        </h2>
        <p class="profile-progress__panel-copy mb-0">
          <%= latest_session.leave_time.in_time_zone.strftime("%b %-d at %-I:%M %p") %>.
          <% if latest_companion_count.positive? %>
            <%= "#{pluralize(latest_companion_count, "other reader")} joined you." %>
          <% else %>
            Solo reading session.
          <% end %>
        </p>
      <% else %>
        <h2 class="profile-progress__panel-title mb-2">Your next session starts here.</h2>
        <p class="profile-progress__panel-copy mb-0">Keep the page light and let the reading speak for itself.</p>
      <% end %>
    </section>
  <% else %>
    <section class="profile-progress__panel profile-progress__panel--timeline">
      <div class="profile-progress__panel-head">
        <div>
          <p class="profile-progress__eyebrow mb-1">Recent sessions</p>
          <h2 class="profile-progress__panel-title mb-0">Reading log</h2>
        </div>
      </div>

      <% if @recent_completed_sessions.any? %>
        <div class="profile-progress__session-list">
          <% @recent_completed_sessions.each do |participant| %>
            <% companion_count = participant.session.other_reader_count_for(current_user) %>
            <article class="profile-progress__session-item">
              <div class="profile-progress__session-main">
                <p class="profile-progress__session-date mb-1"><%= participant.leave_time.in_time_zone.strftime("%b %-d") %></p>
                <h3 class="profile-progress__session-title mb-1"><%= "#{participant.credited_minutes} minute #{participant.session.mode == "structured" ? "Structured" : "Silent"} session" %></h3>
                <p class="profile-progress__session-copy mb-0">
                  <% if companion_count.positive? %>
                    <%= "#{pluralize(companion_count, "other reader")} in the room." %>
                  <% else %>
                    Solo reading session.
                  <% end %>
                </p>
              </div>
              <div class="profile-progress__session-meta">
                <span class="profile-progress__session-badge"><%= participant.leave_time.in_time_zone.strftime("%-I:%M %p") %></span>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="profile-progress__empty">
          <p class="profile-progress__panel-copy mb-3">You have not completed a reading session yet.</p>
          <%= link_to "Start reading", new_session_path, class: "sessions-home__primary-action sessions-home__primary-action--inline" %>
        </div>
      <% end %>
    </section>
  <% end %>
</section>

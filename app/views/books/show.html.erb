<section class="book-detail">
  <article class="book-detail__panel">
    <div class="book-detail__layout">
      <% if @the_book.image_url.present? %>
        <%= image_tag(@the_book.image_url, class: 'book-detail__cover', alt: "#{@the_book.title} cover") %>
      <% else %>
        <div class="book-detail__cover-placeholder" aria-hidden="true">
          <span><%= @the_book.title.to_s.first&.upcase || 'N' %></span>
        </div>
      <% end %>

      <div class="book-detail__content">
        <div>
          <p class="page-eyebrow mb-1">Library</p>
          <h1 class="page-title mb-2"><%= @the_book.title %></h1>
          <p class="book-detail__author mb-0">by <%= @the_book.author&.name.presence || 'Unknown author' %></p>
        </div>

        <% if @the_book.description.present? %>
          <p class="book-detail__description mb-0"><%= @the_book.description %></p>
        <% else %>
          <div class="book-detail__empty">No description has been added for this book yet.</div>
        <% end %>

        <div class="book-detail__meta-list">
          <% if @the_book.page_length.present? %>
            <div class="book-detail__meta-item">
              <span>Length</span>
              <strong><%= @the_book.page_length %> pages</strong>
            </div>
          <% end %>
          <% if @the_book.year.present? %>
            <div class="book-detail__meta-item">
              <span>Year</span>
              <strong><%= @the_book.year %></strong>
            </div>
          <% end %>
          <% if @the_book.genre.present? %>
            <div class="book-detail__meta-item">
              <span>Genre</span>
              <strong><%= @the_book.genre %></strong>
            </div>
          <% end %>
          <div class="book-detail__meta-item">
            <span>Added</span>
            <strong><%= @the_book.created_at.to_date.strftime('%b %-d, %Y') %></strong>
          </div>
        </div>

        <div class="book-detail__actions">
          <%= link_to 'Back to Library', library_back_path, class: 'btn btn-secondary' %>
          <%= link_to 'Discover more', search_path(tab: 'books'), class: 'btn btn-primary' %>
        </div>
      </div>
    </div>
  </article>
</section>

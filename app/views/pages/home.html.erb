<%
  live_presence_label =
    if @live_presence_count.positive?
      "#{pluralize(@live_presence_count, 'reader')} here now"
    else
      "A quiet room, ready when you are"
    end

  shelf_ready_count = @progress_snapshot[:reading] + @progress_snapshot[:queued]

  open_rooms_copy =
    if @active_sessions.any?
      "#{pluralize(@active_sessions.count, 'open room').capitalize} ready to join."
    else
      "No rooms are open this moment, but the next one can begin gently with you."
    end

  shelf_copy =
    if shelf_ready_count == 1
      "1 book is already waiting on your shelf."
    elsif shelf_ready_count.positive?
      "#{shelf_ready_count} books are already waiting on your shelf."
    else
      "One book is enough to make this page feel ready whenever you are."
    end

  presence_copy =
    if @live_presence_count.positive?
      "Presence stays soft here. You can feel other readers nearby without the page turning into a dashboard."
    else
      "Even when the room is still, Home should feel warm, welcoming, and ready for a quiet start."
    end

  continue_reading = @session_entry_readings.first
  additional_shelf_readings =
    if continue_reading.present?
      @session_entry_readings.drop(1)
    else
      @session_entry_readings
    end
%>

<section class="sessions-home">
  <header class="sessions-home__hero">
    <div class="sessions-home__hero-layout">
      <div class="sessions-home__hero-copy">
        <p class="sessions-home__eyebrow mb-2">Welcome back</p>
        <h1 class="sessions-home__title mb-2">Find your place to begin.</h1>
        <p class="sessions-home__lede">Start a quiet session or join others reading right now.</p>

        <div class="sessions-home__presence-cloud">
          <div class="sessions-home__presence-pill">
            <span class="sessions-home__presence-dot" aria-hidden="true"></span>
            <span><%= live_presence_label %></span>
          </div>

          <p class="sessions-home__presence-copy"><%= presence_copy %></p>

          <div class="sessions-home__presence-soft-list">
            <p class="sessions-home__presence-soft-item mb-0"><%= open_rooms_copy %></p>
            <p class="sessions-home__presence-soft-item mb-0"><%= shelf_copy %></p>
          </div>

          <% if feature_flags.presence_visibility == "avatars" && @presence_readers.any? %>
            <% reader_names = @presence_readers.first(3).map { |reader| reader.name.presence || reader.username.presence || "A reader" } %>
            <div class="sessions-home__presence-people">
              <div class="sessions-home__presence-avatars" aria-hidden="true">
                <% @presence_readers.first(4).each do |reader| %>
                  <%= image_tag(reader.avatar.presence || "default_avatar.png", alt: "", class: "sessions-home__presence-avatar") %>
                <% end %>
              </div>

              <p class="sessions-home__presence-caption mb-0">
                <% if reader_names.one? %>
                  <%= reader_names.first %> is already reading nearby<%= @live_presence_count > 1 ? ", with others nearby too." : "." %>
                <% else %>
                  <%= reader_names.to_sentence %> are already reading nearby<%= @live_presence_count > reader_names.count ? ", with others nearby too." : "." %>
                <% end %>
              </p>
            </div>
          <% elsif @live_presence_count == 1 %>
            <p class="sessions-home__presence-caption mb-0">One reader is already settled in.</p>
          <% elsif @live_presence_count.positive? %>
            <p class="sessions-home__presence-caption mb-0"><%= "#{pluralize(@live_presence_count, "reader")} are already sharing quiet time." %></p>
          <% else %>
            <p class="sessions-home__presence-caption mb-0">It is peaceful at the moment. Starting a session can be the first light on the page.</p>
          <% end %>
        </div>
      </div>

      <aside class="sessions-home__hero-aside">
        <div>
          <p class="sessions-home__section-eyebrow mb-1">Start here</p>

          <% if @current_session_participant.present? %>
            <h2 class="sessions-home__hero-card-title mb-2">Your active room is still waiting for you.</h2>
            <p class="sessions-home__hero-card-copy mb-0">Slip back into the session already in progress, or start another whenever you want a fresh beginning.</p>
          <% else %>
            <h2 class="sessions-home__hero-card-title mb-2">Begin with one clear next step.</h2>
            <p class="sessions-home__hero-card-copy mb-0">Start a reading session with your usual settings, then join the rest of the flow from a calmer place.</p>
          <% end %>
        </div>

        <div class="sessions-home__hero-actions">
          <% if @current_session_participant.present? %>
            <%= link_to "Return to Active Session", session_path(@current_session_participant.session), class: "sessions-home__primary-action sessions-home__primary-action--hero" %>
          <% else %>
            <%= link_to "Start reading", new_session_path, class: "sessions-home__primary-action sessions-home__primary-action--hero" %>
          <% end %>
        </div>

        <p class="sessions-home__hero-note">
          Your usual start is <%= feature_flags.session_length %> quiet minutes in <%= feature_flags.session_type.titleize %> Mode.
          <% if @current_session_participant.present? %>
            <%= link_to "Start another session", new_session_path, class: "sessions-home__hero-note-link" %>
          <% else %>
            <%= link_to "Go to library", library_path, class: "sessions-home__hero-note-link" %>
          <% end %>
        </p>
      </aside>
    </div>
  </header>

  <% if @active_sessions.any? || continue_reading.present? %>
    <div class="sessions-home__topfold <%= "sessions-home__topfold--single" if @active_sessions.blank? || continue_reading.blank? %>">
      <% if @active_sessions.any? %>
        <section class="sessions-home__panel sessions-home__panel--rooms">
          <div class="sessions-home__panel-head">
            <div>
              <p class="sessions-home__section-eyebrow mb-1">Active rooms</p>
              <h2 class="sessions-home__section-title mb-1">Join a room already underway.</h2>
              <p class="sessions-home__section-copy mb-0">See who is settled in and step in when one feels right.</p>
            </div>
          </div>

          <div class="session-stack">
            <% @active_sessions.each do |session| %>
              <%= render "session_card", session: session, current_session_participant: @current_session_participant %>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if continue_reading.present? %>
        <% book = continue_reading.book %>
        <% author_name = book.author&.name.presence || "Unknown author" %>
        <% action_label = continue_reading.status == "reading" ? "Continue reading" : "Start from this book" %>
        <% next_progress = continue_reading.status == "finished" ? 0 : continue_reading.progress.to_i %>

        <aside class="sessions-home__panel sessions-home__panel--quiet sessions-home__continue-panel">
          <div class="sessions-home__panel-head sessions-home__panel-head--compact">
            <div>
              <p class="sessions-home__section-eyebrow mb-1">Continue reading</p>
              <h2 class="sessions-home__section-title mb-1">Keep one nearby next step.</h2>
              <p class="sessions-home__section-copy mb-0">A single book, kept close without crowding the page.</p>
            </div>
          </div>

          <article class="entry-card entry-card--compact">
            <div class="entry-card__top">
              <div>
                <p class="entry-card__eyebrow mb-1"><%= continue_reading.status == "reading" ? "Continue gently" : "Ready when you are" %></p>
                <h3 class="entry-card__title mb-1"><%= book.title %></h3>
                <p class="entry-card__author mb-0">by <%= author_name %></p>
              </div>
              <span class="entry-card__metric">
                <%= continue_reading.status == "reading" ? "#{continue_reading.progress.presence || 0}% in" : "On your shelf" %>
              </span>
            </div>

            <div class="entry-card__actions">
              <% if continue_reading.status == "reading" %>
                <%= link_to action_label, book_path(book), class: "sessions-home__secondary-action sessions-home__secondary-action--compact" %>
              <% else %>
                <%= button_to action_label,
                  update_reading_path(continue_reading),
                  method: :post,
                  params: { status: "reading", progress: next_progress, return_to: home_path },
                  class: "sessions-home__secondary-action sessions-home__secondary-action--button sessions-home__secondary-action--compact" %>
              <% end %>
              <%= link_to "Open book", book_path(book), class: "entry-card__link" %>
            </div>
          </article>
        </aside>
      <% end %>
    </div>
  <% end %>

  <div class="sessions-home__deferred-stack">
    <% if continue_reading.blank? || additional_shelf_readings.any? %>
      <section class="sessions-home__panel">
        <div class="sessions-home__panel-head">
          <div>
            <p class="sessions-home__section-eyebrow mb-1">Your shelf</p>
            <h2 class="sessions-home__section-title mb-1">More ways to ease back in.</h2>
            <p class="sessions-home__section-copy mb-0">A few nearby reading options, kept lower on the page.</p>
          </div>
        </div>

        <% if additional_shelf_readings.any? %>
          <div class="entry-stack">
            <% additional_shelf_readings.each do |reading| %>
              <% book = reading.book %>
              <% author_name = book.author&.name.presence || "Unknown author" %>
              <% action_label = reading.status == "reading" ? "Continue reading" : "Start from this book" %>
              <% next_progress = reading.status == "finished" ? 0 : reading.progress.to_i %>

              <article class="entry-card">
                <div class="entry-card__top">
                  <div>
                    <p class="entry-card__eyebrow mb-1"><%= reading.status == "reading" ? "Continue gently" : "Ready when you are" %></p>
                    <h3 class="entry-card__title mb-1"><%= book.title %></h3>
                    <p class="entry-card__author mb-0">by <%= author_name %></p>
                  </div>
                  <span class="entry-card__metric">
                    <%= reading.status == "reading" ? "#{reading.progress.presence || 0}% in" : "On your shelf" %>
                  </span>
                </div>

                <div class="entry-card__actions">
                  <% if reading.status == "reading" %>
                    <%= link_to action_label, book_path(book), class: "sessions-home__secondary-action sessions-home__secondary-action--compact" %>
                  <% else %>
                    <%= button_to action_label,
                      update_reading_path(reading),
                      method: :post,
                      params: { status: "reading", progress: next_progress, return_to: home_path },
                      class: "sessions-home__secondary-action sessions-home__secondary-action--button sessions-home__secondary-action--compact" %>
                  <% end %>
                  <%= link_to "Open book", book_path(book), class: "entry-card__link" %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="sessions-home__empty-state">
            <p class="mb-1">Your shelf is still quiet.</p>
            <p class="mb-3">Add a book first, then Home can turn it into a softer place to begin.</p>
            <div class="sessions-home__inline-actions">
              <%= link_to "Find a book", search_path(tab: "books"), class: "sessions-home__secondary-action sessions-home__secondary-action--compact" %>
              <%= link_to "Go to library", library_path, class: "entry-card__link" %>
            </div>
          </div>
        <% end %>
      </section>
    <% end %>

    <div class="sessions-home__secondary-grid">
      <section class="sessions-home__panel sessions-home__panel--quiet">
      <div>
        <p class="sessions-home__section-eyebrow mb-1">Your rhythm</p>
        <h2 class="sessions-home__section-title mb-1">Progress stays available, not loud.</h2>
        <p class="sessions-home__section-copy mb-0">Keep a gentle sense of what is in motion without turning Home into a dashboard.</p>
      </div>

      <div class="progress-list" aria-label="Reading progress overview">
        <span class="progress-list__item"><strong><%= @progress_snapshot[:reading] %></strong> reading</span>
        <span class="progress-list__item"><strong><%= @progress_snapshot[:queued] %></strong> queued</span>
        <span class="progress-list__item"><strong><%= @progress_snapshot[:finished] %></strong> finished</span>
      </div>
      </section>

      <section class="sessions-home__panel sessions-home__panel--quiet">
        <div class="sessions-home__panel-head">
          <div>
            <p class="sessions-home__section-eyebrow mb-1">Elsewhere in Nouvelle</p>
            <h2 class="sessions-home__section-title mb-1">The rest of the app, kept nearby.</h2>
            <p class="sessions-home__section-copy mb-0">Library, discovery, and notes stay within reach without crowding the start of your visit.</p>
          </div>
        </div>

        <div class="secondary-surface-grid mt-3">
          <%= link_to library_path, class: "secondary-surface-card" do %>
            <span class="secondary-surface-card__eyebrow">Library</span>
            <strong class="secondary-surface-card__title">Tend your shelves</strong>
            <span class="secondary-surface-card__copy">Update status, privacy, and progress when you want to make small adjustments.</span>
          <% end %>

          <%= link_to search_path(tab: "books"), class: "secondary-surface-card" do %>
            <span class="secondary-surface-card__eyebrow">Discover</span>
            <strong class="secondary-surface-card__title">Find a next book</strong>
            <span class="secondary-surface-card__copy">Browse when you want a fresh option without losing the calm of the page.</span>
          <% end %>

          <%= link_to posts_path, class: "secondary-surface-card" do %>
            <span class="secondary-surface-card__eyebrow">Activity</span>
            <strong class="secondary-surface-card__title">Reading notes and updates</strong>
            <span class="secondary-surface-card__copy">Visit the social layer when you want it, not before you have had a chance to settle in.</span>
          <% end %>
        </div>

        <% if @recent_post.present? %>
          <% recent_author = @recent_post.creator.name.presence || @recent_post.creator.username.presence || "A reader" %>
          <% recent_book = @recent_post.book&.title.presence || "their current read" %>
          <article class="feed-teaser mt-3">
            <p class="feed-teaser__eyebrow mb-0">A recent note</p>
            <p class="feed-teaser__copy mb-0">
              <strong><%= recent_author %></strong> shared an update about <strong><%= recent_book %></strong>.
            </p>
            <div class="sessions-home__inline-actions">
              <%= link_to "Open activity", posts_path, class: "entry-card__link" %>
            </div>
          </article>
        <% end %>
      </section>
    </div>
  </div>
</section>

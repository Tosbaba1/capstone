<section class="sessions-home__panel sessions-home__panel--quiet sessions-home__section">
  <header class="sessions-home__panel-head sessions-home__panel-head--stack">
    <p class="sessions-home__section-eyebrow mb-1">Active rooms</p>
    <h2 class="sessions-home__section-title mb-1">Join others reading now</h2>
    <p class="sessions-home__section-copy mb-0">Pick a room already in progress, or start the first one.</p>
  </header>

  <% if active_sessions.any? %>
    <div class="sessions-home__room-scroller" aria-label="Active rooms">
      <% active_sessions.each do |session| %>
        <%= render "pages/home/active_room_card", session: session, current_session_participant: current_session_participant %>
      <% end %>
    </div>
  <% else %>
    <div class="sessions-home__empty-state sessions-home__empty-state--inline">
      <p class="mb-0">Be the first to start a session</p>
    </div>
  <% end %>
</section>

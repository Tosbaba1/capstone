<%
  shelf_ready_count = @progress_snapshot[:reading] + @progress_snapshot[:queued]
  open_room_count = @active_sessions.count
%>

<div class="sessions-home__deferred-stack">
  <section class="sessions-home__panel sessions-home__panel--quiet sessions-home__section">
    <div class="sessions-home__panel-head sessions-home__panel-head--stack">
      <div>
        <p class="sessions-home__section-eyebrow mb-1">Around now</p>
        <h2 class="sessions-home__section-title mb-1">Extra context when you want it</h2>
        <p class="sessions-home__section-copy mb-0">Live reading, open rooms, and shelf count stay available without taking over the page.</p>
      </div>
    </div>

    <div class="sessions-home__stats-row">
      <span class="progress-list__item"><strong><%= @live_presence_count %></strong> reading now</span>
      <span class="progress-list__item"><strong><%= open_room_count %></strong> open <%= open_room_count == 1 ? "room" : "rooms" %></span>
      <span class="progress-list__item"><strong><%= shelf_ready_count %></strong> books ready</span>
    </div>

    <% if feature_flags.presence_visibility == "avatars" && @presence_readers.any? %>
      <div class="sessions-home__presence-strip">
        <div class="sessions-home__presence-avatars" aria-hidden="true">
          <% @presence_readers.first(4).each do |reader| %>
            <%= image_tag(reader.avatar.presence || "default_avatar.png", alt: "", class: "sessions-home__presence-avatar") %>
          <% end %>
        </div>

        <p class="sessions-home__section-copy mb-0">
          <%= pluralize(@live_presence_count, "reader") %> are active right now.
        </p>
      </div>
    <% end %>
  </section>

  <section class="sessions-home__panel sessions-home__panel--quiet sessions-home__section">
    <div class="sessions-home__panel-head sessions-home__panel-head--stack">
      <div>
        <p class="sessions-home__section-eyebrow mb-1">Elsewhere in Nouvelle</p>
        <h2 class="sessions-home__section-title mb-1">More to explore</h2>
        <p class="sessions-home__section-copy mb-0">Library, discovery, and reading updates live below the main reading flow.</p>
      </div>
    </div>

    <div class="secondary-surface-grid mt-3">
      <%= link_to library_path, class: "secondary-surface-card" do %>
        <span class="secondary-surface-card__eyebrow">Library</span>
        <strong class="secondary-surface-card__title">Go to library</strong>
        <span class="secondary-surface-card__copy">Update your books, progress, and privacy settings.</span>
      <% end %>

      <%= link_to search_path(tab: "books"), class: "secondary-surface-card" do %>
        <span class="secondary-surface-card__eyebrow">Discover</span>
        <strong class="secondary-surface-card__title">Find a book</strong>
        <span class="secondary-surface-card__copy">Browse for your next read without leaving the reading flow.</span>
      <% end %>

      <%= link_to posts_path, class: "secondary-surface-card" do %>
        <span class="secondary-surface-card__eyebrow">Activity</span>
        <strong class="secondary-surface-card__title">Reading updates</strong>
        <span class="secondary-surface-card__copy">See notes and conversations after the core reading sections.</span>
      <% end %>
    </div>

    <% if @recent_post.present? %>
      <% recent_author = @recent_post.creator.name.presence || @recent_post.creator.username.presence || "A reader" %>
      <% recent_book = @recent_post.book&.title.presence || "their current read" %>
      <article class="feed-teaser mt-3">
        <p class="feed-teaser__eyebrow mb-0">Latest activity</p>
        <p class="feed-teaser__copy mb-0">
          <strong><%= recent_author %></strong> shared an update about <strong><%= recent_book %></strong>.
        </p>
        <div class="sessions-home__inline-actions">
          <%= link_to "Open activity", posts_path, class: "entry-card__link" %>
        </div>
      </article>
    <% end %>
  </section>
</div>

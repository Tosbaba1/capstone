<section class="relationship-page">
  <article class="page-panel">
    <p class="page-eyebrow mb-1">Followers</p>
    <h1 class="page-title mb-2"><%= @user == current_user ? 'Your followers' : "#{@user.name}'s followers" %></h1>
    <p class="page-copy mb-0">Keep the people around this reading life visible, but quiet.</p>
  </article>

  <% if @requests.any? %>
    <section class="page-panel page-panel--soft">
      <p class="page-eyebrow mb-1">Requests</p>
      <h2 class="h4 mb-3">Follower requests</h2>
      <div class="relationship-page__list">
        <% @requests.each do |req| %>
          <article class="relationship-page__item">
            <div class="relationship-page__item-main">
              <%= image_tag(req.sender.avatar.presence || 'default_avatar.png', class: 'relationship-page__item-avatar', alt: req.sender.name) %>
              <div>
                <%= link_to (req.sender.name.presence || req.sender.username), user_path(req.sender), class: 'relationship-page__item-name' %>
                <p class="relationship-page__item-meta mb-0">@<%= req.sender.username %></p>
              </div>
            </div>
            <% if @user == current_user %>
              <div class="relationship-page__item-actions">
                <%= button_to 'Accept', accept_followrequest_path(req), method: :post, class: 'btn btn-success' %>
                <%= button_to 'Decline', decline_followrequest_path(req), method: :post, class: 'btn btn-danger' %>
              </div>
            <% end %>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @followers.any? %>
    <div class="relationship-page__list">
      <% @followers.each do |u| %>
        <article class="relationship-page__item">
          <div class="relationship-page__item-main">
            <%= image_tag(u.avatar.presence || 'default_avatar.png', class: 'relationship-page__item-avatar', alt: u.name) %>
            <div>
              <%= link_to (u.name.presence || u.username), user_path(u), class: 'relationship-page__item-name' %>
              <p class="relationship-page__item-meta mb-0">@<%= u.username %></p>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="relationship-page__empty">No followers yet.</div>
  <% end %>
</section>

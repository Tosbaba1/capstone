<div class="library-chat">
  <div>
    <h1 class="library-chat__title mb-0">Ask the Librarian</h1>
  </div>

  <%= form_with url: library_ai_chat_path, method: :post, local: true do %>
    <div class="mb-3">
      <%= text_area_tag :message, nil, class: 'form-control', placeholder: 'Describe your mood or what you want to read...' %>
    </div>
    <%= submit_tag 'Ask Librarian', class: 'btn btn-primary' %>
  <% end %>

  <div class="library-chat__messages">
    <% @chat_history.each do |msg| %>
      <% next if msg.role == 'system' %>
      <article class="library-chat__message <%= 'library-chat__message--assistant' if msg.role == 'assistant' %>">
        <p class="library-chat__speaker mb-2"><%= msg.role == 'user' ? 'You' : 'Librarian' %></p>
        <%= simple_format(msg.content, {}, wrapper_tag: 'div') %>
      </article>
    <% end %>
  </div>
</div>

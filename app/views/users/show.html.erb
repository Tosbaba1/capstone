<% profile_name = @user.name.presence || @user.username.presence || "Reader" %>
<% profile_handle = @user.username.presence || @user.email.to_s.split("@").first %>

<section class="public-profile app-page-stack">
  <article class="public-profile__hero">
    <% if @user.banner.present? %>
      <p class="public-profile__banner mb-0"><%= @user.banner %></p>
    <% end %>

    <div class="public-profile__identity">
      <%= image_tag(@user.avatar.presence || 'default_avatar.png', class: 'public-profile__avatar', alt: profile_name) %>
      <div>
        <h1 class="public-profile__name mb-1"><%= profile_name %></h1>
        <p class="public-profile__handle mb-2">@<%= profile_handle %></p>
        <p class="public-profile__bio mb-0">
          <%= @user.bio.presence || "A quiet place to keep a reading life visible without making it loud." %>
        </p>
      </div>
    </div>
  </article>

  <section class="app-support-grid app-support-grid--split public-profile__supporting">
    <div class="page-panel page-panel--soft public-profile__support-card">
      <p class="page-eyebrow mb-2">Profile</p>
      <div class="public-profile__stats">
        <span class="public-profile__stat"><strong><%= @user.completed_session_count %></strong> sessions</span>
        <%= link_to followers_user_path(@user), class: 'public-profile__stat' do %>
          <strong><%= @user.followers.count %></strong> followers
        <% end %>
        <%= link_to following_user_path(@user), class: 'public-profile__stat' do %>
          <strong><%= @user.following.count %></strong> following
        <% end %>
      </div>
    </div>

    <div class="page-panel page-panel--soft public-profile__support-card">
      <p class="page-eyebrow mb-2">Actions</p>
      <div class="public-profile__actions">
        <% unless @user == current_user %>
          <% fr = current_user.sentfollowrequests.find_by(recipient: @user) %>
          <% if current_user.following.include?(@user) %>
            <%= link_to 'Unfollow', unfollow_user_path(@user), method: :delete, class: 'btn btn-secondary' %>
          <% elsif fr&.status == 'pending' %>
            <span class="public-profile__status">Request sent</span>
          <% else %>
            <%= link_to 'Follow', follow_user_path(@user), method: :post, class: 'btn btn-primary' %>
          <% end %>
          <% if !@user.is_private || current_user.following.include?(@user) %>
            <%= link_to 'View Library', library_user_path(@user), class: 'btn btn-secondary' %>
          <% end %>
        <% else %>
          <%= link_to 'View Progress', profile_path, class: 'btn btn-secondary' %>
          <%= link_to 'My Library', library_path, class: 'btn btn-primary' %>
        <% end %>
      </div>
    </div>
  </section>

  <% if !@restricted %>
    <ul class="nav nav-tabs app-tabs-row">
      <li class="nav-item">
        <%= link_to 'Notes', user_path(@user), class: "nav-link #{params[:tab].blank? || params[:tab] == 'nouvelles' ? 'active' : ''}" %>
      </li>
      <li class="nav-item">
        <%= link_to 'Reshares', user_path(@user, tab: 'renous'), class: "nav-link #{params[:tab] == 'renous' ? 'active' : ''}" %>
      </li>
      <li class="nav-item">
        <%= link_to 'Likes', user_path(@user, tab: 'likes'), class: "nav-link #{params[:tab] == 'likes' ? 'active' : ''}" %>
      </li>
      <li class="nav-item">
        <%= link_to 'Comments', user_path(@user, tab: 'comments'), class: "nav-link #{params[:tab] == 'comments' ? 'active' : ''}" %>
      </li>
      <li class="nav-item">
        <%= link_to 'Badges', user_path(@user, tab: 'badges'), class: "nav-link #{params[:tab] == 'badges' ? 'active' : ''}" %>
      </li>
    </ul>
  <% end %>

  <div class="public-profile__body">
    <% if @restricted %>
      <div class="public-profile__empty">This account is private.</div>
    <% end %>

    <% unless @restricted %>
      <% case params[:tab] %>
      <% when 'likes' %>
        <% posts = @user.liked_posts.order(created_at: :desc) %>
      <% when 'comments' %>
        <% posts = Post.joins(:comments).where(comments: { commenter_id: @user.id }).distinct.order(created_at: :desc) %>
      <% when 'renous' %>
        <% posts = @user.renoued_posts.order('renous.created_at DESC') %>
      <% when 'badges' %>
        <% posts = [] %>
      <% else %>
        <% posts = @user.posts.order(created_at: :desc) %>
      <% end %>

      <% if params[:tab] == 'badges' %>
        <% if @user.badges.any? %>
          <div class="public-profile__badge-grid">
            <% @user.badges.each do |badge| %>
              <article class="public-profile__badge">
                <%= image_tag badge.image_url, class: 'img-fluid', alt: badge.name if badge.image_url.present? %>
                <strong><%= badge.name %></strong>
                <small><%= badge.description %></small>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="public-profile__empty">No badges earned yet.</div>
        <% end %>
      <% else %>
        <div class="public-profile__posts">
          <% posts.each do |post| %>
            <%= render 'posts/post_card', post: post %>
          <% end %>
        </div>

        <% if posts.empty? %>
          <div class="public-profile__empty">No reading notes to display.</div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

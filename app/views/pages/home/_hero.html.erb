<% primary_path = current_session_participant.present? ? session_path(current_session_participant.session) : new_session_path %>

<section class="sessions-home__hero sessions-home__hero--simple">
  <div class="sessions-home__hero-copy">
    <h1 class="sessions-home__title mb-0">Start reading now.</h1>
    <%= link_to "Start reading", primary_path, class: "sessions-home__primary-action sessions-home__primary-action--hero" %>

    <% if current_session_participant.present? %>
      <p class="sessions-home__hero-note mb-0">Your current session is still active.</p>
    <% end %>
  </div>
</section>

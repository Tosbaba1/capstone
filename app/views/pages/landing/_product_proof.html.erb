<section class="landing-section landing-section--proof" aria-labelledby="landing-product-proof">
  <div class="landing-proof">
    <div class="landing-proof__copy">
      <p class="landing-section__kicker mb-0">Product proof</p>
      <h2 id="landing-product-proof" class="landing-section__title mb-0"><%= landing_page_content[:product_proof_line] %></h2>
    </div>

    <div class="landing-preview-card landing-preview-card--proof">
      <div class="landing-preview-card__topline">
        <p class="landing-preview-card__eyebrow mb-0">Session preview</p>
        <p class="landing-preview-card__status mb-0">Live now</p>
      </div>

      <div class="landing-preview-card__proof-body">
        <h3 class="landing-preview-card__title mb-0">Evening pages</h3>
        <p class="landing-preview-card__proof-copy mb-0">Three readers are in the room, the timer is running, and the interface stays out of the way.</p>
      </div>

      <div class="landing-preview-card__meta" aria-label="Proof details">
        <span class="landing-preview-card__meta-item">18 min left</span>
        <span class="landing-preview-card__meta-item">Silent co-reading</span>
      </div>
    </div>
  </div>
</section>

<% if @user == current_user %>
  <ul class="nav nav-tabs app-tabs-row mb-4">
    <li class="nav-item">
      <%= link_to 'Shared Shelf', library_path(tab: 'public'), class: "nav-link #{@active_tab == 'public' ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Private Shelf', library_path(tab: 'private'), class: "nav-link #{@active_tab == 'private' ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Librarian', library_path(tab: 'ai'), class: "nav-link #{@active_tab == 'ai' ? 'active' : ''}" %>
    </li>
  </ul>
<% end %>

<% if @active_tab == 'ai' %>
  <section class="library-shell app-page-stack">
    <header class="library-hero mb-4">
      <p class="library-hero__eyebrow mb-2">Librarian</p>
      <div class="library-hero__header">
        <div>
          <h1 class="library-hero__title mb-2">Ask for a quieter recommendation</h1>
          <p class="library-hero__copy mb-0">
            Describe the mood you want to read in, and the librarian will keep the suggestions close to that feeling.
          </p>
        </div>
      </div>
    </header>

    <div class="page-panel page-panel--soft">
      <%= render 'library_ai_chat' %>
    </div>
  </section>
<% else %>
  <% editable = @user == current_user %>
  <% library_title = editable ? 'Your Library' : "#{@user.name}'s Library" %>
  <% shelf_label = editable ? (@active_tab == 'private' ? 'Private shelf' : 'Public shelf') : 'Public shelf' %>

  <section class="library-shell app-page-stack">
    <header class="library-hero mb-4">
      <p class="library-hero__eyebrow mb-2"><%= editable ? shelf_label : "Library" %></p>
      <div class="library-hero__header">
        <div>
          <h1 class="library-hero__title mb-2"><%= library_title %></h1>
          <p class="library-hero__copy mb-0">
            Keep the books that support your next session close at hand, then step back into reading.
          </p>
        </div>
        <% if editable %>
          <div class="library-hero__actions">
            <%= link_to "Add Book", search_path(tab: "books"), class: "btn btn-primary" %>
            <% if @current_session_participant.present? %>
              <%= link_to "Return to Session", session_path(@current_session_participant.session), class: "btn btn-secondary" %>
            <% else %>
              <%= link_to "Start Reading Session", new_session_path, class: "btn btn-secondary" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </header>

    <%= render 'library_shelf_section',
      title: 'Currently Reading',
      subtitle: 'Books with your bookmark still tucked inside.',
      readings: @reading_now,
      editable: editable %>

    <%= render 'library_shelf_section',
      title: 'Want to Read',
      subtitle: 'Books waiting patiently in your next-up stack.',
      readings: @want_to_read,
      editable: editable %>

    <%= render 'library_shelf_section',
      title: 'Finished',
      subtitle: 'Books you have already carried all the way to the last page.',
      readings: @finished,
      editable: editable %>
  </section>
<% end %>

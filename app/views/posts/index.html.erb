<% explore_active = params[:tab] == 'explore' %>
<% feed_path = explore_active ? posts_path(tab: 'explore') : posts_path %>
<% pill_label = explore_active ? 'Following shelf' : 'Explore shelf' %>
<% pill_path = explore_active ? posts_path : posts_path(tab: 'explore') %>

<section class="feed-shell">
  <header class="feed-hero mb-3">
    <div class="feed-hero__inner">
      <div class="feed-hero__content">
        <p class="feed-hero__eyebrow mb-0">Nouvelle Feed</p>
        <h1 class="feed-hero__title mb-0">A social feed for readers in the middle of a book.</h1>
        <p class="feed-hero__copy mb-0">
          Share the page you reached, the line you underlined, or the feeling you closed the cover with.
        </p>
      </div>
      <%= link_to pill_label, pill_path,
        class: 'feed-hero__pill',
        aria: { label: "Switch to #{pill_label.sub(' shelf', '')} feed" } %>
    </div>
  </header>

  <ul class="nav nav-tabs feed-tabs mb-3 justify-content-center">
    <li class="nav-item">
      <%= link_to 'Following', posts_path, class: "nav-link #{explore_active ? '' : 'active'}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Explore', posts_path(tab: 'explore'), class: "nav-link #{explore_active ? 'active' : ''}" %>
    </li>
  </ul>

  <div class="posts-feed">
    <% @list_of_posts.each do |post| %>
      <%= render 'posts/post_card', post: post %>
    <% end %>
  </div>
</section>

<section class="feed-composer-drawer" id="feed-composer">
  <%= link_to feed_path, class: 'feed-composer-drawer__backdrop', aria: { label: 'Close composer' } do %>
  <% end %>

  <div class="feed-composer-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="feed-composer-title">
    <div class="feed-composer-drawer__chrome">
      <p class="feed-composer-drawer__eyebrow mb-0">Compose</p>
      <%= link_to feed_path, class: 'feed-composer-drawer__close', aria: { label: 'Close composer' } do %>
        <i class="bi bi-x-lg"></i>
      <% end %>
    </div>

    <%= render 'posts/composer',
      composer_books: @composer_books,
      composer_id: nil,
      composer_classes: 'feed-composer--drawer',
      heading_id: 'feed-composer-title' %>
  </div>
</section>

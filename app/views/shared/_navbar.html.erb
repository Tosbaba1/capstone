<%
  page_label = @page_title.presence || "Welcome back"
  unread_count = user_signed_in? ? current_user.notifications.unread.count : 0
  reading_active = request.path == root_path || request.path == home_path || request.path == new_session_path
  library_active = request.path == library_path || request.path.match?(%r{\A/users/\d+/library\z})
  discover_active = request.path == search_path || request.path.start_with?("/books")
  activity_active = request.path.start_with?("/posts")
  inbox_active = request.path == notifications_path
  nav_items = [
    {
      label: "Read",
      path: root_path,
      icon: "bi-house-door",
      active: reading_active
    },
    {
      label: "Library",
      path: library_path,
      icon: "bi-book-half",
      active: library_active
    },
    {
      label: "Discover",
      path: search_path,
      icon: "bi-compass",
      active: discover_active
    },
    {
      label: "Activity",
      path: posts_path,
      icon: "bi-journal-text",
      active: activity_active
    },
    {
      label: "Inbox",
      path: notifications_path,
      icon: "bi-bell",
      active: inbox_active,
      badge: unread_count
    }
  ]
%>

<header class="app-header">
  <div class="container">
    <div class="app-header__inner">
      <div class="app-header__lead">
        <%= link_to root_path, class: "nouvelle-mark", aria: { label: "Nouvelle home" } do %>
          <span class="nouvelle-mark__seal" aria-hidden="true">
            <span class="nouvelle-mark__glyph">N</span>
          </span>
          <span class="nouvelle-mark__wording">
            <span class="nouvelle-mark__name">Nouvelle</span>
            <span class="nouvelle-mark__tag">Quiet reading sessions</span>
          </span>
        <% end %>
      </div>

      <div class="app-header__meta">
        <p class="app-header__eyebrow mb-0">Session-first reading with quiet company</p>
        <p class="app-header__title mb-0"><%= page_label %></p>
      </div>

      <div class="app-header__tail">
        <% if user_signed_in? %>
          <% if request.path == profile_path %>
            <%= link_to "Sign Out", destroy_user_session_path, method: :delete, class: "app-header__action" %>
          <% else %>
            <%= link_to profile_path, class: "app-header__profile", aria: { label: "Open your profile" } do %>
              <%= image_tag(current_user.avatar.presence || "default_avatar.png", alt: current_user.name, class: "app-header__avatar") %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</header>

<% if user_signed_in? %>
  <div class="app-bottom-bar" role="presentation">
    <nav class="app-bottom-nav container" aria-label="Primary">
      <div class="app-bottom-nav__surface">
        <div class="app-bottom-nav__items">
          <% nav_items.each do |item| %>
            <% link_classes = ["app-bottom-nav__link", ("is-active" if item[:active])].compact.join(" ") %>
            <% link_label = item[:label] == "Inbox" && unread_count.positive? ? "#{item[:label]}, #{unread_count} unread" : item[:aria_label].presence || item[:label] %>
            <%= link_to item[:path], class: link_classes, aria: { label: link_label } do %>
              <span class="app-bottom-nav__icon-wrap">
                <span class="app-bottom-nav__icon">
                  <i class="bi <%= item[:icon] %>"></i>
                </span>
                <% if item[:badge].to_i.positive? %>
                  <span class="app-bottom-nav__badge"><%= [item[:badge], 9].min %></span>
                <% end %>
              </span>
              <span class="app-bottom-nav__label"><%= item[:label] %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    </nav>
  </div>
<% end %>

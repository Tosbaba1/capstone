<section class="notifications-page app-page-stack">
  <ul class="nav nav-tabs app-tabs-row mb-3">
    <li class="nav-item">
      <%= link_to 'All', notifications_path, class: "nav-link #{params[:tab].blank? ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Progress', notifications_path(tab: 'progress'), class: "nav-link #{%w[progress milestones].include?(params[:tab]) ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Responses', notifications_path(tab: 'responses'), class: "nav-link #{%w[responses comments].include?(params[:tab]) ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Appreciation', notifications_path(tab: 'appreciation'), class: "nav-link #{%w[appreciation likes].include?(params[:tab]) ? 'active' : ''}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Requests', notifications_path(tab: 'requests'), class: "nav-link #{%w[requests follow_requests].include?(params[:tab]) ? 'active' : ''}" %>
    </li>
  </ul>

  <div class="notifications-page__list">
    <% @notifications.each do |notification| %>
      <article class="notification-card <%= 'is-unread' unless notification.read? %>">
        <div class="notification-card__main">
          <div>
            <p class="notification-card__meta mb-2"><%= time_ago_in_words(notification.created_at) %> ago</p>
            <p class="notification-card__title">
              <strong><%= notification.actor.name %></strong> <%= notification.action %>
              <% if notification.notifiable.is_a?(Post) %>
                <%= link_to 'View note', post_path(notification.notifiable) %>
              <% elsif notification.notifiable.is_a?(Book) %>
                <%= link_to notification.notifiable.title, book_path(notification.notifiable) %>
              <% end %>
            </p>
          </div>

          <% unless notification.read? %>
            <span class="notification-card__state">New</span>
          <% end %>
        </div>

        <div class="notification-card__actions">
          <% if notification.notifiable.is_a?(Followrequest) && notification.action == 'sent you a follow request' && notification.notifiable.status == 'pending' %>
            <%= button_to 'Accept', accept_followrequest_path(notification.notifiable), method: :post, class: 'btn btn-success', form_class: 'notification-card__action-form' %>
            <%= button_to 'Decline', decline_followrequest_path(notification.notifiable), method: :post, class: 'btn btn-danger', form_class: 'notification-card__action-form' %>
          <% end %>

          <% if notification.read? %>
            <%= button_to 'Mark unread', mark_notification_unread_path(notification), method: :post, class: 'btn btn-secondary', form_class: 'notification-card__action-form' %>
          <% else %>
            <%= button_to 'Mark read', mark_notification_read_path(notification), method: :post, class: 'btn btn-secondary', form_class: 'notification-card__action-form' %>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>

  <% if @notifications.empty? %>
    <div class="page-panel page-panel--soft">
      <p class="page-copy mb-0">No updates waiting in your inbox.</p>
    </div>
  <% end %>
</section>

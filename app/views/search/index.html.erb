<section class="library-shell discover-search">
  <header class="library-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end">
      <div>
        <p class="library-hero__eyebrow mb-2">Search</p>
        <h1 class="library-hero__title mb-0">Find your next book</h1>
      </div>
    </div>
  </header>

  <ul class="nav nav-tabs app-tabs-row mb-3">
    <li class="nav-item">
      <%= link_to 'Books', search_path(tab: 'books', q: params[:q]), class: "nav-link #{'active' if @active_tab == 'books'}" %>
    </li>
    <li class="nav-item">
      <%= link_to 'Readers', search_path(tab: 'users', q: params[:q]), class: "nav-link #{'active' if @active_tab == 'users'}" %>
    </li>
  </ul>

  <%= form_with url: search_path, method: :get, local: true, class: 'discover-search__form mb-4' do %>
    <%= hidden_field_tag :tab, @active_tab %>
    <div class="input-group">
      <% if @active_tab == 'books' %>
        <%= text_field_tag :q, params[:q], class: 'form-control', placeholder: 'Search books by title or author', list: 'book-suggestions', data: { controller: 'book-suggest', action: 'input->book-suggest#search', 'book-suggest-target': 'input' } %>
        <datalist id="book-suggestions" data-book-suggest-target="list"></datalist>
      <% else %>
        <%= text_field_tag :q, params[:q], class: 'form-control', placeholder: 'Search readers by name or username' %>
      <% end %>
      <button class="btn btn-primary">Search</button>
    </div>
  <% end %>

  <% if @active_tab == 'books' %>
    <div class="discover-search__results">
      <% Array(@external_books['docs']).each do |book| %>
        <article class="discover-search__card">
          <div class="discover-search__book">
            <% if book['cover_i'] %>
              <%= image_tag(OpenLibraryClient.cover_url(book['cover_i'], 'M'), class: 'discover-search__cover', alt: "#{book['title']} cover") %>
            <% else %>
              <div class="discover-search__cover discover-search__cover--placeholder" aria-hidden="true">
                <span><%= book['title'].to_s.first&.upcase || 'N' %></span>
              </div>
            <% end %>

            <div class="discover-search__copy">
              <h2 class="discover-search__title mb-0">
                <%= link_to book['title'], book_details_path(work_id: book['key'].split('/').last, edition_id: book['edition_key']&.first) %>
              </h2>
              <% if book['author_name'] %>
                <p class="discover-search__meta mb-0">by <%= book['author_name'].join(', ') %></p>
              <% end %>

              <div class="discover-search__actions">
                <%= link_to 'Details', book_details_path(work_id: book['key'].split('/').last, edition_id: book['edition_key']&.first), class: 'btn btn-secondary' %>
                <%= form_with url: '/books/import', method: :post, local: true, class: 'discover-search__add-form' do %>
                  <%= hidden_field_tag :work_id, book['key'].split('/').last %>
                  <%= select_tag :status,
                    options_for_select(Reading::STATUS_OPTIONS, 'want_to_read'),
                    class: 'form-select form-select-sm discover-search__status' %>
                  <button class="btn btn-primary">Add</button>
                <% end %>
              </div>
            </div>
          </div>
        </article>
      <% end %>
    </div>
    <% if params[:q].present? && Array(@external_books['docs']).empty? %>
      <p class="discover-search__empty">No books found.</p>
    <% end %>
  <% else %>
    <% if @recent_searches.any? %>
      <section class="discover-search__recent">
        <p class="page-eyebrow mb-1">Recent</p>
        <h2 class="h5 mb-0">Recent reader searches</h2>
        <ul class="discover-search__recent-list">
          <% @recent_searches.each do |search| %>
            <li><%= search.query %></li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <div class="discover-search__results">
      <% @users.each do |user| %>
        <article class="discover-search__card">
          <div class="discover-search__reader">
            <%= image_tag(user.avatar.presence || 'default_avatar.png', class: 'discover-search__avatar', alt: user.name) %>
            <div class="discover-search__copy">
              <h2 class="discover-search__title mb-0"><%= link_to user.name, user_path(user) %></h2>
              <p class="discover-search__meta mb-0">@<%= user.username %></p>
            </div>
          </div>
        </article>
      <% end %>
    </div>

    <% if params[:q].present? && @users.empty? %>
      <p class="discover-search__empty">No readers found.</p>
    <% end %>
  <% end %>
</section>

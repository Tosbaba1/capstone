<% book = reading.book %>
<% author_name = book.author&.name.presence || "Unknown author" %>
<% progress_label = reading.status == "reading" ? "#{reading.progress.presence || 0}% read" : "Up next" %>
<% next_progress = reading.status == "finished" ? 0 : reading.progress.to_i %>

<article class="home-book-chip">
  <div class="home-book-chip__copy">
    <p class="home-book-chip__eyebrow mb-1"><%= reading.status == "reading" ? "Continue reading" : "Up next" %></p>
    <h3 class="home-book-chip__title mb-1"><%= book.title %></h3>
    <p class="home-book-chip__meta mb-0"><%= "#{author_name} · #{progress_label}" %></p>
  </div>

  <div class="home-book-chip__actions">
    <% if reading.status == "reading" %>
      <%= link_to "Continue reading", book_path(book), class: "entry-card__link home-book-chip__link" %>
    <% else %>
      <%= button_to "Start reading",
        update_reading_path(reading),
        method: :post,
        params: { status: "reading", progress: next_progress, return_to: home_path },
        class: "sessions-home__secondary-action sessions-home__secondary-action--button sessions-home__secondary-action--compact" %>
    <% end %>
  </div>
</article>

<section class="note-detail">
  <div class="note-detail__header">
    <%= link_to 'Back to Activity', posts_path, class: 'btn btn-secondary' %>
    <% if @the_post.creator == current_user %>
      <%= link_to 'Delete note', "/delete_post/#{@the_post.id}", class: 'btn app-button--danger' %>
    <% end %>
  </div>

  <%= render 'posts/post_card', post: @the_post, show_view_link: false %>

  <% if @the_post.creator == current_user %>
    <article class="note-detail__edit">
      <p class="page-eyebrow mb-1">Edit</p>
      <h2 class="h4 mb-2">Refine your note</h2>
      <p class="note-detail__copy mb-0">Keep the edit surface simple so the writing still feels like part of the same place.</p>

      <%= form_with model: @the_post, url: "/modify_post/#{@the_post.id}", method: :post, local: true do |f| %>
        <div>
          <%= f.label :content, class: 'form-label' %>
          <%= f.text_area :content, class: 'form-control' %>
        </div>
        <div>
          <%= f.label :book_id, 'Book', class: 'form-label' %>
          <%= f.text_field :book_id, class: 'form-control' %>
        </div>
        <div class="note-detail__actions">
          <%= f.submit 'Update note', class: 'btn btn-primary' %>
        </div>
      <% end %>
    </article>
  <% end %>
</section>

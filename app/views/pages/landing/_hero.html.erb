<section class="landing-hero">
  <div class="landing-hero__copy">
    <p class="page-eyebrow mb-2">Read with others, not alone</p>
    <h1 class="landing-hero__title mb-3">Find your place to begin</h1>
    <p class="landing-hero__copy-text mb-0">Read quietly alongside others</p>

    <div class="landing-hero__actions">
      <%= link_to "Start reading", landing_primary_auth_path, class: "sessions-home__primary-action landing-hero__cta" %>
      <p class="landing-hero__hint mb-0">
        <%= landing_primary_auth_prompt %> to join your first room.
      </p>
    </div>
  </div>

  <aside class="landing-hero__aside content-box" aria-label="What Nouvelle feels like">
    <p class="landing-hero__aside-label mb-2">Nouvelle</p>
    <p class="landing-hero__aside-copy mb-0">A place where you read with others, not alone.</p>
  </aside>
</section>
